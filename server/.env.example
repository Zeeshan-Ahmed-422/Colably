PORT=5050

# PostgreSQL connection string used by Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Default local Postgres install:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/influencer_campaign_platform

JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173

# Anyone who knows this code can register an admin account at /admin/sign-in.
# Default works out of the box; change on production to lock it down.
ADMIN_INVITE_CODE=collably-admin-invite
