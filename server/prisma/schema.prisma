// Prisma schema — Influencer Campaign Collaboration Platform
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---------------------------------------------------------------

enum Role {
  admin
  brand
  influencer
}

enum UserStatus {
  active
  suspended
}

enum Platform {
  instagram
  tiktok
  youtube
  twitter
  facebook
  linkedin
}

enum Niche {
  fashion
  beauty
  fitness
  food
  travel
  tech
  gaming
  finance
  education
  lifestyle
  parenting
  comedy
}

enum CampaignStatus {
  draft
  open
  closed
  archived
  flagged
}

enum ApplicationKind {
  application
  invitation
}

enum ApplicationStatus {
  pending
  shortlisted
  accepted
  rejected
  invited
  declined
  withdrawn
}

enum CollaborationStatus {
  active
  completed
  cancelled
}

enum DeliverableStatus {
  todo
  in_progress
  submitted
  approved
  rejected
}

// --- MODELS --------------------------------------------------------------

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  role      Role
  avatarUrl String     @default("")
  status    UserStatus @default(active)

  // Brand-specific profile fields (nullable for influencer/admin)
  companyName String?
  website     String?
  industry    String?
  description String?

  // Influencer-specific profile fields
  bio            String?
  location       String?
  niches         Niche[] @default([])
  totalFollowers Int     @default(0) // denormalized sum of handle followers

  handles                  SocialHandle[]
  campaigns                Campaign[]      @relation("BrandCampaigns")
  moderatedCampaigns       Campaign[]      @relation("ReviewedBy")
  applicationsAsInfluencer Application[]   @relation("AppInfluencer")
  applicationsAsBrand      Application[]   @relation("AppBrand")
  collabsAsBrand           Collaboration[] @relation("CollabBrand")
  collabsAsInfluencer      Collaboration[] @relation("CollabInfluencer")
  messages                 Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialHandle {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  platform       Platform
  handle         String
  followers      Int      @default(0)
  engagementRate Float    @default(0)

  @@index([userId])
  @@index([platform])
}

model Campaign {
  id                   String         @id @default(cuid())
  brand                User           @relation("BrandCampaigns", fields: [brandId], references: [id], onDelete: Cascade)
  brandId              String
  title                String
  description          String
  budget               Float
  currency             String         @default("USD")
  platforms            Platform[]     @default([])
  niches               Niche[]        @default([])
  minFollowers         Int            @default(0)
  deliverablesTemplate String[]       @default([])
  deadline             DateTime?
  status               CampaignStatus @default(open)

  // Moderation
  flagged          Boolean   @default(false)
  moderationReason String    @default("")
  reviewedBy       User?     @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedById     String?
  reviewedAt       DateTime?

  applications   Application[]
  collaborations Collaboration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId])
  @@index([status])
}

model Application {
  id           String            @id @default(cuid())
  campaign     Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId   String
  influencer   User              @relation("AppInfluencer", fields: [influencerId], references: [id], onDelete: Cascade)
  influencerId String
  brand        User              @relation("AppBrand", fields: [brandId], references: [id], onDelete: Cascade)
  brandId      String
  kind         ApplicationKind
  message      String            @default("")
  proposedRate Float?
  status       ApplicationStatus @default(pending)

  collaboration Collaboration?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, influencerId])
  @@index([brandId])
  @@index([influencerId])
}

model Collaboration {
  id              String              @id @default(cuid())
  campaign        Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId      String
  brand           User                @relation("CollabBrand", fields: [brandId], references: [id], onDelete: Cascade)
  brandId         String
  influencer      User                @relation("CollabInfluencer", fields: [influencerId], references: [id], onDelete: Cascade)
  influencerId    String
  application     Application?        @relation(fields: [applicationId], references: [id])
  applicationId   String?             @unique
  agreedRate      Float?
  status          CollaborationStatus @default(active)
  completionNotes String              @default("")
  completedAt     DateTime?

  deliverables Deliverable[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, influencerId])
  @@index([brandId])
  @@index([influencerId])
}

model Deliverable {
  id              String            @id @default(cuid())
  collaboration   Collaboration     @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  collaborationId String
  title           String
  description     String            @default("")
  dueDate         DateTime?
  status          DeliverableStatus @default(todo)
  proofUrl        String            @default("")
  submissionNote  String            @default("")
  feedback        String            @default("")
  submittedAt     DateTime?
  reviewedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([collaborationId])
}

model Message {
  id              String        @id @default(cuid())
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  collaborationId String
  sender          User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderId        String
  body            String
  readBy          String[]      @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([collaborationId])
}
